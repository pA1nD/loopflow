{
  "name": "loopflow",
  "version": "0.1.0",
  "description": "Minimal Electron canvas + datastore for LLM orchestration UI",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:debug": "LOOPFLOW_DEBUG_PORT=9222 vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "playwright": "^1.48.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
